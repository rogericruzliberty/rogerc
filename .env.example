# ─── Liberty Field App — Environment Variables ─────────────
# Copy this file to .env and fill in your values.

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/liberty_field

# ─── JWT Auth ───────────────────────────────
JWT_SECRET=your-secure-jwt-secret-here
JWT_REFRESH_SECRET=your-secure-refresh-secret-here

# ─── Google OAuth (for Drive integration) ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Redis (for BullMQ export queue) ────────
REDIS_URL=redis://localhost:6379

# ─── Server ─────────────────────────────────
PORT=3000
CORS_ORIGIN=*
NODE_ENV=development

# ─── Mobile App (set in app.json extras or EAS) ─
# API_BASE_URL=https://your-api-domain.com
