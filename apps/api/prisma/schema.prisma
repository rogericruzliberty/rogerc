// Liberty Field App — Prisma Schema
// Full database schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FIELD
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  COMPLETED
  SYNCED
}

enum AttachmentType {
  PHOTO
  VIDEO
  AUDIO
  DOCUMENT
}

enum UploadStatus {
  PENDING
  UPLOADING
  SYNCED
  FAILED
}

enum ContactRoleType {
  BUILDING_MANAGER
  FIRE_ALARM_CONTRACTOR
  SPRINKLER_CONTRACTOR
  EMS_VENDOR
  OTHER
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String
  role               UserRole  @default(FIELD)
  passwordHash       String    @map("password_hash")
  ssoId              String?   @map("sso_id")
  googleAccessToken  String?   @map("google_access_token")
  googleRefreshToken String?   @map("google_refresh_token")
  googleTokenExpiry  DateTime? @map("google_token_expiry")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  projects     Project[]
  submissions  Submission[]

  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  address     String?
  suiteNumber String?       @map("suite_number")
  clientName  String?       @map("client_name")
  status      ProjectStatus @default(ACTIVE)
  createdBy   String        @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  creator     User          @relation(fields: [createdBy], references: [id])
  submissions Submission[]

  @@map("projects")
}

model Submission {
  id          String           @id @default(uuid())
  projectId   String           @map("project_id")
  userId      String           @map("user_id")
  status      SubmissionStatus @default(DRAFT)
  siteName    String?          @map("site_name")
  locationLat Float?           @map("location_lat")
  locationLng Float?           @map("location_lng")
  startedAt   DateTime         @default(now()) @map("started_at")
  completedAt DateTime?        @map("completed_at")
  syncedAt    DateTime?        @map("synced_at")

  project     Project          @relation(fields: [projectId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  answers     Answer[]
  contacts    Contact[]
  attachments FileAttachment[]

  @@map("submissions")
}

model Answer {
  id           String     @id @default(uuid())
  submissionId String     @map("submission_id")
  questionKey  String     @map("question_key")
  value        String?
  isNa         Boolean    @default(false) @map("is_na")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  submission   Submission @relation(fields: [submissionId], references: [id])

  @@unique([submissionId, questionKey])
  @@map("answers")
}

model Contact {
  id           String          @id @default(uuid())
  submissionId String          @map("submission_id")
  name         String
  title        String?
  phone        String?
  email        String?
  company      String?
  roleType     ContactRoleType @default(OTHER) @map("role_type")
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")

  submission   Submission      @relation(fields: [submissionId], references: [id])

  @@map("contacts")
}

model FileAttachment {
  id           String         @id @default(uuid())
  submissionId String         @map("submission_id")
  type         AttachmentType
  filename     String
  mimeType     String?        @map("mime_type")
  sizeBytes    BigInt?        @map("size_bytes")
  driveFileId  String?        @map("drive_file_id")
  driveFolderId String?       @map("drive_folder_id")
  remoteUrl    String?        @map("remote_url")
  uploadStatus UploadStatus   @default(PENDING) @map("upload_status")
  retryCount   Int            @default(0) @map("retry_count")
  createdAt    DateTime       @default(now()) @map("created_at")

  submission   Submission     @relation(fields: [submissionId], references: [id])

  @@map("file_attachments")
}
